// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client"
  output          = "../src/prisma/generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum ReservationStatus {
  PENDING   @map("pending")
  PAID      @map("paid")
  CANCELLED @map("cancelled")
}

enum MidtransStatus {
  PENDING    @map("pending")
  SETTLEMENT @map("settlement")
  EXPIRE     @map("expire")
  DENY       @map("deny")
  CANCEL     @map("cancel")
  CAPTURE    @map("capture")
  FAILURE    @map("failure")
  REFUND     @map("refund")
  CHARGEBACK @map("chargeback")
  PARTIAL_REFUND @map("partial_refund")
  PARTIAL_CHARGEBACK @map("partial_chargeback")
  AUTHORIZED @map("authorized")
}

model User {
  id    String @id @default(uuid())
  email String @unique
  username String @unique
  password String
  saldo Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean @default(false)
  reservations Reservation[]
}

model Reservation {
  id String @id @default(uuid())
  startTime String
  endTime String
  date DateTime
  location String
  court String
  price String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean @default(false)
  status ReservationStatus @default(PENDING)

  user User @relation(fields: [userId], references: [id])
  userId String

  midtrans Midtrans @relation(fields: [midtransId], references: [id])
  midtransId String

}

model Midtrans {
  id String @id @default(uuid())
  orderId String
  grossAmount Int
  token String
  status MidtransStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean @default(false)

  reservation Reservation[]
}
