// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client"
  output          = "../src/prisma/generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  TOPUP
  RESERVATION_PAYMENT
  REFUND
}

enum TransactionStatus {
  PENDING   @map("pending")
  SUCCESS   @map("success")
  CANCELLED @map("cancelled")
}

enum ReservationStatus {
  PENDING   @map("pending")
  PAID      @map("paid")
  CANCELLED @map("cancelled")
}

enum TopupStatus {
  PENDING   @map("pending")
  PAID      @map("paid")
  CANCELLED @map("cancelled")
}

enum PaymentMethod {
  MIDTRANS  @map("midtrans")
  BALANCE   @map("balance")
}

enum MidtransStatus {
  PENDING    @map("pending")
  SETTLEMENT @map("settlement")
  EXPIRE     @map("expire")
  DENY       @map("deny")
  CANCEL     @map("cancel")
  CAPTURE    @map("capture")
  FAILURE    @map("failure")
  REFUND     @map("refund")
  CHARGEBACK @map("chargeback")
  PARTIAL_REFUND @map("partial_refund")
  PARTIAL_CHARGEBACK @map("partial_chargeback")
  AUTHORIZED @map("authorized")
}

model User {
  id    String @id @default(uuid())
  email String @unique
  username String @unique
  password String?
  googleId String? @unique
  balance Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean @default(false)
  reservations Reservation[]
  topups Topup[]
  transactions BalanceTransaction[]
}

model Reservation {
  id String @id @default(uuid())
  startTime String
  endTime String
  date DateTime
  location String
  court String
  price String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean @default(false)
  status ReservationStatus @default(PENDING)
  paymentMethod PaymentMethod @default(MIDTRANS)

  user User @relation(fields: [userId], references: [id])
  userId String

  midtrans Midtrans? @relation(fields: [midtransId], references: [id])
  midtransId String?
}

model Midtrans {
  id String @id @default(uuid())
  orderId String
  grossAmount Int
  token String
  status MidtransStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean @default(false)

  reservation Reservation[]
  topup Topup[]
}

model Topup {
  id String @id @default(uuid())
  amount Int
  status TopupStatus @default(PENDING)
  paymentMethod PaymentMethod @default(MIDTRANS)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean @default(false)

  user User @relation(fields: [userId], references: [id])
  userId String

  midtrans Midtrans? @relation(fields: [midtransId], references: [id])
  midtransId String?
}

model BalanceTransaction {
  id          String   @id @default(uuid())
  amount      Int      // Positif untuk saldo masuk, Negatif untuk saldo keluar
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  referenceId String?  // ID dari Topup atau Reservation terkait
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  userId String
}
